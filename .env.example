# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=localmate
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=localmate
DATABASE_URL=postgresql+asyncpg://localmate:changeme_in_prod@postgres:5432/localmate

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth / JWT ────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Search ─────────────────────────────────────────────────
# Provider: gemini | openai | anthropic
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Vendors API ───────────────────────────────────────────────
VENDOR_API_KEY=change_this_vendor_secret_key

# ── Service URLs (internal docker network) ────────────────────
AUTH_SERVICE_URL=http://auth:8001
USERS_SERVICE_URL=http://users:8002
SEARCH_SERVICE_URL=http://search:8003
TOKENS_SERVICE_URL=http://tokens:8004
VENDORS_SERVICE_URL=http://vendors:8005

# ── Tokens economy ────────────────────────────────────────────
WELCOME_TOKENS=50
CONTACT_OPEN_COST=5
XP_PER_GIG=10

# ── CORS (comma-separated) ────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# Get free API key at https://sendgrid.com (100 emails/day free)
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@localmate.sk
FROM_NAME=LocalMate
APP_URL=http://localhost:3000
